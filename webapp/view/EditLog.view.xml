<mvc:View controllerName="printinglogbook.controller.EditLog"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:svg="http://www.w3.org/2000/svg">

    <Page id="editPage" showHeader="false" enableScrolling="true" class="plbPageBg">
        <content>
            <!-- Shell Header -->
            <html:div class="plbShellHeader">
                <html:div class="plbHeaderLeft">
                    <html:button class="plbMenuBtn" title="Menu">
                        <svg:svg class="plbSvgFill" width="20" height="20" viewBox="0 0 24 24"><svg:path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg:svg>
                    </html:button>
                    <html:div class="plbLogo">
                        <svg:svg class="plbLogoIcon plbSvgFill" width="24" height="24" viewBox="0 0 24 24"><svg:path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg:svg>
                        <html:span class="plbLogoText">AWL Packaging eLog</html:span>
                    </html:div>
                </html:div>
                <html:div class="plbHeaderRight">
                    <html:button class="plbNotifBtn" title="Notifications">
                        <svg:svg class="plbSvgFill" width="20" height="20" viewBox="0 0 24 24"><svg:path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg:svg>
                    </html:button>
                    <html:button class="plbUserBtn" title="User Profile">
                        <html:div class="plbAvatar" id="plbUserAvatarEdit"></html:div>
                        <html:span class="plbUserName" id="plbUserNameEdit"></html:span>
                    </html:button>
                </html:div>
            </html:div>

            <!-- Breadcrumb Bar -->
            <html:div class="plbBreadcrumbBar">
                <html:div class="plbBreadcrumbLeft">
                    <html:button class="plbBreadHome" id="plbBreadHomeBtn">Home</html:button>
                    <html:span class="plbBreadSep">/</html:span>
                    <html:span class="plbBreadCurrent">Log Details</html:span>
                </html:div>
                <html:div class="plbBreadcrumbRight">
                    <html:span class="plbStatusDot"></html:span>
                    System Online
                </html:div>
            </html:div>

            <!-- Main Content -->
            <html:div class="plbMainContent plbAnimateFadeIn">
                <html:div class="plbEditContainer">
                    <!-- Object Header -->
                    <html:div class="plbObjectHeader">
                        <html:h2 class="plbOHTitle" id="plbEditTitle"></html:h2>
                        <html:div class="plbOHSubtitle">
                            <html:span id="plbEditDocId"></html:span>
                            <html:span class="plbOHDot"></html:span>
                            <html:span id="plbEditCompany">Select Company</html:span>
                        </html:div>
                    </html:div>

                    <!-- Form Body -->
                    <html:div class="plbFormBody">
                        <html:form id="plbEditForm">
                            <!-- Hidden ID -->
                            <html:input type="hidden" id="plbFieldId" />

                            <!-- Section: Core Details -->
                            <html:div class="plbFormSection">
                                <html:h3 class="plbFormSectionTitle">Core Details</html:h3>
                                <html:div class="plbFormGrid plbFormGrid3">
                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Date Time <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:input type="datetime-local" class="plbInput" id="plbFieldDateTime" />
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">Shift</html:label>
                                        <html:input type="text" class="plbInput plbInputReadonly" id="plbFieldShift" readonly="true" tabindex="-1" />
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Product Name <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:select class="plbSelect" id="plbFieldProductName">
                                            <html:option value="" disabled="true" selected="true">Select Product</html:option>
                                        </html:select>
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Company Name <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:select class="plbSelect" id="plbFieldCompanyName">
                                            <html:option value="" disabled="true" selected="true">Select Company</html:option>
                                        </html:select>
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Box No. <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:input type="text" class="plbInput plbInputUppercase" id="plbFieldBoxNo" placeholder="e.g. 0770-17" />
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Batch No. <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:input type="text" class="plbInput plbInputUppercase" id="plbFieldBatchNo" placeholder="e.g. ABM030150" />
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Rool No. <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:input type="text" class="plbInput plbInputUppercase" id="plbFieldRollNo" placeholder="e.g. B1" />
                                    </html:div>
                                </html:div>
                            </html:div>

                            <!-- Section: Metrics & Values -->
                            <html:div class="plbFormSection">
                                <html:h3 class="plbFormSectionTitle">Metrics &amp; Values</html:h3>
                                <html:div class="plbFormGrid plbFormGrid4">
                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Gross Weight/Qty (<html:span id="plbUomGross">Kgs</html:span>) <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:div class="plbWeightInputWrap">
                                            <html:input type="number" step="0.01" class="plbInput" id="plbFieldGrossWeight" />
                                            <html:button type="button" class="plbScanBtn" id="plbScanGrossBtn" title="Scan from Camera">
                                                <svg:svg class="plbScanIcon plbSvgFill" viewBox="0 0 24 24"><svg:circle cx="12" cy="12" r="3.2"/><svg:path d="M9 2L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3.17L15 2H9zm3 15c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5z"/></svg:svg>
                                            </html:button>
                                        </html:div>
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Net Weight/Qty (<html:span id="plbUomNet">Kgs</html:span>) <html:span class="plbRequired">*</html:span></html:span>
                                            <html:span class="plbFieldHint">(Auto: +1<html:span id="plbUomHint">Kgs</html:span>)</html:span>
                                        </html:label>
                                        <html:div class="plbWeightInputWrap">
                                            <html:input type="number" step="0.01" class="plbInput" id="plbFieldNetWeight" />
                                            <html:button type="button" class="plbScanBtn" id="plbScanNetBtn" title="Scan from Camera">
                                                <svg:svg class="plbScanIcon plbSvgFill" viewBox="0 0 24 24"><svg:circle cx="12" cy="12" r="3.2"/><svg:path d="M9 2L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3.17L15 2H9zm3 15c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5z"/></svg:svg>
                                            </html:button>
                                        </html:div>
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Counter <html:span class="plbRequired">*</html:span></html:span>
                                        </html:label>
                                        <html:input type="number" class="plbInput plbCounterInput" id="plbFieldCounter" />
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Price <html:span class="plbRequired">*</html:span></html:span>
                                            <html:span class="plbFieldHint">(Auto from Product)</html:span>
                                        </html:label>
                                        <html:div class="plbPriceWrap">
                                            <html:span class="plbRupeeSign">₹</html:span>
                                            <html:input type="number" step="0.01" class="plbInput plbPriceInput plbInputReadonly" id="plbFieldPrice" readonly="true" />
                                        </html:div>
                                    </html:div>
                                </html:div>
                            </html:div>

                            <!-- Section: Execution -->
                            <html:div class="plbFormSection">
                                <html:h3 class="plbFormSectionTitle">Execution</html:h3>
                                <html:div class="plbFormGrid plbFormGrid2">
                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">
                                            <html:span>Operator Name <html:span class="plbRequired">*</html:span></html:span>
                                            <html:span class="plbSetToMe" id="plbSetToMeBtn">Set to Me</html:span>
                                        </html:label>
                                        <html:select class="plbSelect" id="plbFieldOperatorName">
                                            <html:option value="" disabled="true" selected="true">Select Operator</html:option>
                                        </html:select>
                                    </html:div>

                                    <html:div class="plbFieldGroup">
                                        <html:label class="plbFieldLabel">Remark</html:label>
                                        <html:textarea class="plbTextarea" id="plbFieldRemark" rows="2" placeholder="Add any operational notes or remarks here..."></html:textarea>
                                    </html:div>
                                </html:div>
                            </html:div>
                        </html:form>
                    </html:div>

                    <!-- Form Footer -->
                    <html:div class="plbFormFooter">
                        <html:button class="plbCancelBtn" id="plbCancelEditBtn" type="button">Cancel</html:button>
                        <html:button class="plbSaveBtn" id="plbSaveLogBtn" type="button">Save Document</html:button>
                    </html:div>
                </html:div>
            </html:div>

            <!-- Footer -->
            <html:div class="plbFooter">
                <html:p class="plbFooterText">SAP UI5 / Fiori Design Guideline Implementation © 2026</html:p>
            </html:div>
        </content>
    </Page>
</mvc:View>
