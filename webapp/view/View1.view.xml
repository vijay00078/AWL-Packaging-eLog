<mvc:View controllerName="printinglogbook.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:svg="http://www.w3.org/2000/svg"
    xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">

    <Page id="page" showHeader="false" enableScrolling="true" class="plbPageBg">
        <content>
            <!-- Shell Header -->
            <html:div class="plbShellHeader">
                <html:div class="plbHeaderLeft">
                    <html:button class="plbMenuBtn" title="Menu">
                        <svg:svg class="plbSvgFill" width="20" height="20" viewBox="0 0 24 24"><svg:path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg:svg>
                    </html:button>
                    <html:div class="plbLogo">
                        <svg:svg class="plbLogoIcon plbSvgFill" width="24" height="24" viewBox="0 0 24 24"><svg:path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg:svg>
                        <html:span class="plbLogoText">AWL Packaging eLog</html:span>
                    </html:div>
                </html:div>
                <html:div class="plbHeaderRight">
                    <html:button class="plbNotifBtn" title="Notifications">
                        <svg:svg class="plbSvgFill" width="20" height="20" viewBox="0 0 24 24"><svg:path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg:svg>
                    </html:button>
                    <html:button class="plbUserBtn" title="User Profile">
                        <html:div class="plbAvatar" id="plbUserAvatarOverview"></html:div>
                        <html:span class="plbUserName" id="plbUserNameOverview"></html:span>
                    </html:button>
                </html:div>
            </html:div>

            <!-- Breadcrumb Bar -->
            <html:div class="plbBreadcrumbBar">
                <html:div class="plbBreadcrumbLeft">
                    <html:span class="plbBreadHome">Home</html:span>
                    <html:span class="plbBreadSep">/</html:span>
                    <html:span class="plbBreadCurrent">Overview &amp; Log Book</html:span>
                </html:div>
                <html:div class="plbBreadcrumbRight">
                    <html:span class="plbStatusDot"></html:span>
                    System Online
                </html:div>
            </html:div>

            <!-- Main Content -->
            <html:div class="plbMainContent plbAnimateFadeIn">
                <!-- KPI Cards -->
                <html:div class="plbKpiGrid" id="plbKpiGrid">
                    <!-- KPI 1: Total Counter -->
                    <html:div class="plbKpiCard">
                        <html:div class="plbKpiHeader">
                            <html:span class="plbKpiLabel">Total Counter / Volume</html:span>
                            <svg:svg class="plbKpiIcon plbKpiIconBlue plbSvgFill" viewBox="0 0 24 24"><svg:path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg:svg>
                        </html:div>
                        <html:span class="plbKpiValue" id="plbKpiTotalCounter"></html:span>
                        <html:div class="plbKpiSubtext">
                            <html:span>Impressions Logged</html:span>
                        </html:div>
                        <html:div class="plbKpiProgress">
                            <html:div class="plbKpiBar plbKpiBarBlue" style="width:100%"></html:div>
                        </html:div>
                    </html:div>

                    <!-- KPI 2: Total Value -->
                    <html:div class="plbKpiCard">
                        <html:div class="plbKpiHeader">
                            <html:span class="plbKpiLabel">Total Value (Price)</html:span>
                            <svg:svg class="plbKpiIcon plbKpiIconGreen plbSvgFill" viewBox="0 0 24 24"><svg:path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg:svg>
                        </html:div>
                        <html:span class="plbKpiValue plbKpiValueGreen" id="plbKpiTotalValue"></html:span>
                        <html:div class="plbKpiSubtext">
                            <html:span id="plbKpiFromLogs"></html:span>
                        </html:div>
                        <html:div class="plbKpiProgress">
                            <html:div class="plbKpiBar plbKpiBarGreen" style="width:100%"></html:div>
                        </html:div>
                    </html:div>

                    <!-- KPI 3: Weight Yield -->
                    <html:div class="plbKpiCard">
                        <html:div class="plbKpiHeader">
                            <html:span class="plbKpiLabel">Weight Yield (Net/Gross)</html:span>
                            <svg:svg class="plbKpiIcon plbKpiIconOrange plbSvgFill" viewBox="0 0 24 24"><svg:path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg:svg>
                        </html:div>
                        <html:span class="plbKpiValue" id="plbKpiWeightYield"></html:span>
                        <html:div class="plbKpiSubtext">
                            <html:span class="plbSubMedium" id="plbKpiNetWeight"></html:span>
                            <html:span class="plbSubSep">|</html:span>
                            <html:span id="plbKpiGrossWeight"></html:span>
                        </html:div>
                        <html:div class="plbKpiProgress">
                            <html:div class="plbKpiBar" id="plbKpiYieldBar"></html:div>
                        </html:div>
                    </html:div>

                    <!-- KPI 4: Product Distribution -->
                    <html:div class="plbKpiCard">
                        <html:span class="plbKpiLabel" style="margin-bottom:12px;display:block">Product Distribution</html:span>
                        <html:div id="plbProductDistribution">
                        </html:div>
                    </html:div>
                </html:div>

                <!-- Table Container -->
                <html:div class="plbTableContainer">
                    <!-- Toolbar -->
                    <html:div class="plbTableToolbar">
                        <html:div>
                            <html:h2 class="plbToolbarTitle">AWL Packaging eLog</html:h2>
                            <html:span class="plbToolbarCount" id="plbTableCount"></html:span>
                        </html:div>
                        <html:div class="plbToolbarActions">
                            <html:div class="plbGroupByWrap">
                                <html:span class="plbGroupByLabel">Group By:</html:span>
                                <html:select class="plbGroupSelect" id="plbGroupSelect">
                                    <html:option value="none">None</html:option>
                                    <html:option value="productName">Product</html:option>
                                    <html:option value="date">Date</html:option>
                                    <html:option value="companyName">Company</html:option>
                                    <html:option value="operatorName">Operator</html:option>
                                    <html:option value="shift">Shift</html:option>
                                </html:select>
                            </html:div>
                            <html:div class="plbSearchWrap">
                                <svg:svg class="plbSearchIcon plbSvgFill" viewBox="0 0 24 24"><svg:path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg:svg>
                                <html:input type="text" class="plbSearchInput" id="plbSearchField" placeholder="Search product, company, operator..." />
                            </html:div>
                            <html:span class="plbToolbarSep"></html:span>
                            <html:button class="plbCreateBtn" id="plbCreateEntryBtn">
                                <svg:svg class="plbCreateIcon plbSvgFill" viewBox="0 0 24 24"><svg:path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg:svg>
                                Create Entry
                            </html:button>
                        </html:div>
                    </html:div>

                    <!-- Table -->
                    <Table id="logTable" items="{appData>/logs}" class="plbUI5Table" noDataText="No logs found">
                        <columns>
                            <Column demandPopin="false" width="140px">
                                <Text text="Date &amp; Time" />
                            </Column>
                            <Column demandPopin="true" minScreenWidth="Tablet" popinDisplay="Block">
                                <Text text="Product &amp; Box No." />
                            </Column>
                            <Column demandPopin="true" minScreenWidth="Tablet" popinDisplay="Block">
                                <Text text="Company Details" />
                            </Column>
                            <Column demandPopin="true" minScreenWidth="Desktop" popinDisplay="Block">
                                <Text text="Measurement (UOM)" />
                            </Column>
                            <Column demandPopin="true" minScreenWidth="Desktop" popinDisplay="Block">
                                <Text text="Counter &amp; Price" />
                            </Column>
                            <Column demandPopin="true" minScreenWidth="Desktop" popinDisplay="Block">
                                <Text text="Operator &amp; Remarks" />
                            </Column>
                            <Column hAlign="End" width="100px" demandPopin="true" minScreenWidth="Tablet" popinDisplay="WithoutHeader">
                                <Text text="Actions" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Top" type="Inactive">
                                <cells>
                                    <VBox class="sapUiSmallMarginTopBottom">
                                        <Text text="{ path: 'appData>dateTime', formatter: '.formatDateMain' }" class="plbDateMain" />
                                        <HBox alignItems="Center" class="plbTimeRow sapUiTinyMarginTop sapUiTinyMarginBottom">
                                            <core:Icon src="sap-icon://time-entry-request" class="sapUiTinyMarginEnd" size="12px" />
                                            <Text text="{ path: 'appData>dateTime', formatter: '.formatTimeRow' }" />
                                        </HBox>
                                        <core:HTML content="{ path: 'appData>', formatter: '.formatShiftBadge' }" />
                                    </VBox>

                                    <VBox class="sapUiSmallMarginTopBottom">
                                        <Link text="{appData>productName}" press=".onEditAction" customData:logId="{appData>id}" class="plbProductLinkText" />
                                        <HBox alignItems="Center" class="sapUiTinyMarginTop">
                                            <Text text="Box:" class="plbBoxLabelGray sapUiTinyMarginEnd" />
                                            <Text text="{appData>boxNo}" class="plbBoxLabel" />
                                        </HBox>
                                    </VBox>

                                    <VBox class="sapUiSmallMarginTopBottom">
                                        <Text text="{appData>companyName}" class="plbCompanyName" />
                                        <Text text="Batch: {appData>batchNo} | Rool: {appData>rollNo}" class="plbBatchInfo sapUiTinyMarginTop" />
                                    </VBox>

                                    <VBox class="sapUiSmallMarginTopBottom">
                                        <HBox justifyContent="SpaceBetween" alignItems="Center" width="150px" class="sapUiTinyMarginBottom">
                                            <Text text="Gross:" class="plbWeightLabel" />
                                            <Text text="{ path: 'appData>', formatter: '.formatGrossWeight' }" class="plbWeightVal" />
                                        </HBox>
                                        <HBox justifyContent="SpaceBetween" alignItems="Center" width="150px">
                                            <Text text="Net:" class="plbWeightLabel" />
                                            <ObjectNumber number="{ path: 'appData>', formatter: '.formatNetWeightNum' }" unit="{ path: 'appData>', formatter: '.formatNetWeightUnit' }" state="{ path: 'appData>', formatter: '.formatNetState' }" />
                                        </HBox>
                                    </VBox>

                                    <VBox class="sapUiSmallMarginTopBottom">
                                        <HBox alignItems="Baseline" class="sapUiTinyMarginBottom">
                                            <Text text="{ path: 'appData>counter', formatter: '.formatCounter' }" class="plbCounterVal sapUiTinyMarginEnd" />
                                            <Text text="units" class="plbCounterUnit" />
                                        </HBox>
                                        <ObjectNumber number="{ path: 'appData>price', formatter: '.formatPrice' }" state="Success" />
                                    </VBox>

                                    <VBox class="sapUiSmallMarginTopBottom">
                                        <HBox alignItems="Center" class="plbOperatorRow sapUiTinyMarginBottom">
                                            <Text text="{ path: 'appData>operatorName', formatter: '.formatAvatar' }" class="plbOperatorAvatar sapUiTinyMarginEnd" />
                                            <Text text="{appData>operatorName}" />
                                        </HBox>
                                        <Text text="{appData>remark}" class="plbRemarkText" wrapping="false" tooltip="{appData>remark}" />
                                    </VBox>

                                    <HBox justifyContent="End" alignItems="Center" class="sapUiSmallMarginTopBottom">
                                        <Button icon="sap-icon://edit" type="Transparent" press=".onEditAction" customData:logId="{appData>id}" class="plbEditBtn sapUiTinyMarginEnd" />
                                        <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteAction" customData:logId="{appData>id}" class="plbDeleteBtn" />
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </html:div>
            </html:div>

            <!-- Footer -->
            <html:div class="plbFooter">
                <html:p class="plbFooterText">SAP UI5 / Fiori Design Guideline Implementation © 2026</html:p>
            </html:div>
        </content>
    </Page>
</mvc:View>